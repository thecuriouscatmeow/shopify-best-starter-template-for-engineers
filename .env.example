# Copy this file to `src/.env` and fill in your Shopify custom-app credentials.
# Create a custom app in your Shopify admin (Settings → Apps and sales channels →
# Develop apps), grant it the scopes you need (e.g. read/write_products,
# read/write_publications, read_locations, inventory), then copy its credentials here.
#
# These are read by scripts/shopify-token.sh to mint a client_credentials token.
# NEVER commit the real .env — it is gitignored.

client_id=your_custom_app_client_id_here
client_secret=your_custom_app_client_secret_here

# Also set your store handle at the top of the seed scripts:
#   scripts/shopify-token.sh, scripts/seed-data.mjs, scripts/seed-images.mjs
#   STORE = "your-store.myshopify.com"
