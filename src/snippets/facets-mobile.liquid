{% comment %}
  Renders the mobile filter/sort drawer — the <menu-drawer> that slides in on
  small viewports. Contains its own filter groups (distinct mobile markup from
  the desktop facets-filter-group), the mobile sort <select>, and the apply/clear
  footers. Every contract anchor facets.js + global.js (MenuDrawer) bind to is
  preserved byte-for-byte:
    - <menu-drawer data-breakpoint="mobile"> + native <details>/<summary>
    - #FacetFiltersFormMobile (facets.js .closest('menu-drawer'), form.id checks)
    - .mobile-facets__open / .mobile-facets__count / .sorting (mobileElementSelectors)
    - .mobile-facets__details + .mobile-facets__list / .facets-wrap (morph targets)
    - .js-filter (morph unit), Details-Mobile-* / FacetMobile-* ids, data-index
    - input class EXACTLY "mobile-facets__checkbox" (facets.js className equality)
    - <facet-remove>, <price-range>, swatch-input render (product_form_id=FacetFiltersFormMobile)
    - price-facet render with id_prefix 'Mobile-Filter-' and NO filter_type (mobile variant)
    - #SortBy-mobile, name="sort_by"
    - onclick "this.closest('.mobile-facets__wrapper').querySelector('summary').click()"

  Accepts:
  - results: {Object} Collection or Search object
  - results_url: {String} clear-all URL
  - enable_filtering: {Boolean}
  - enable_sorting: {Boolean}
  - filter_type: {String} 'vertical' | 'horizontal' | 'drawer'
  - sort_by: {String} current sort value

  Usage:
  {% render 'facets-mobile', results: results, results_url: results_url, enable_filtering: enable_filtering, enable_sorting: enable_sorting, filter_type: filter_type, sort_by: sort_by %}
{% endcomment %}

<menu-drawer
  class="mobile-facets__wrapper{% if filter_type == 'horizontal' or filter_type == 'vertical' %} desktop:hidden{% endif %}"
  data-breakpoint="mobile"
>
  <details class="mobile-facets__disclosure">
    <summary class="mobile-facets__open-wrapper">
      <span class="mobile-facets__open{% if filter_type == 'drawer' and enable_filtering == false %} desktop:hidden{% endif %}">
        <span class="mobile-facets__open-icon">
          {{- 'icon-filter.svg' | inline_asset_content -}}
        </span>
        <span class="mobile-facets__open-label desktop:hidden">
          {%- if enable_filtering and enable_sorting -%}
            {{ 'products.facets.filter_and_sort' | t }}
          {%- elsif enable_filtering -%}
            {{ 'products.facets.filter_button' | t }}
          {%- elsif enable_sorting -%}
            {{ 'products.facets.sort_button' | t }}
          {%- endif -%}
        </span>
        <span class="mobile-facets__open-label hidden desktop:inline">
          {%- if enable_filtering -%}
            {{ 'products.facets.filter_button' | t }}
          {%- endif -%}
        </span>
      </span>
      <span tabindex="0" class="mobile-facets__close">
        <span class="mobile-facets__close-icon">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </span>
    </summary>
    <facet-filters-form>
      <form id="FacetFiltersFormMobile" class="mobile-facets">
        <div class="mobile-facets__inner">
          <div class="mobile-facets__header">
            <div class="mobile-facets__header-inner">
              <h2 class="mobile-facets__heading desktop:hidden">
                {%- if enable_filtering and enable_sorting -%}
                  {{ 'products.facets.filter_and_sort' | t }}
                {%- elsif enable_filtering -%}
                  {{ 'products.facets.filter_button' | t }}
                {%- elsif enable_sorting -%}
                  {{ 'products.facets.sort_button' | t }}
                {%- endif -%}
              </h2>
              <h2 class="mobile-facets__heading hidden desktop:block">
                {%- if enable_filtering -%}
                  {{ 'products.facets.filter_button' | t }}
                {%- endif -%}
              </h2>
              <p class="mobile-facets__count">
                {%- if results.results_count -%}
                  {{ 'templates.search.results_with_count' | t: terms: results.terms, count: results.results_count }}
                {%- elsif results.products_count == results.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: results.products_count }}
                {%- else -%}
                  {{
                    'products.facets.product_count'
                    | t: product_count: results.products_count, count: results.all_products_count
                  }}
                {%- endif -%}
              </p>
            </div>
          </div>
          <div
            id="FacetsWrapperMobile"
            class="mobile-facets__main has-submenu"
          >
            {%- if enable_filtering -%}
              {%- for filter in results.filters -%}
                {% liquid
                  assign presentation = filter.presentation | default: 'text'
                  if presentation == 'image'
                    assign visual_layout_class = 'facets-layout facets-layout-grid facets-layout-grid--' | append: presentation
                  else
                    assign visual_layout_class = 'facets-layout facets-layout-list facets-layout-list--' | append: presentation
                  endif
                %}

                {% case filter.type %}
                  {% when 'boolean', 'list' %}
                    <details
                      id="Details-Mobile-{{ filter.param_name | escape }}-{{ section.id }}"
                      class="mobile-facets__details js-filter"
                      data-index="mobile-{{ forloop.index }}"
                    >
                      <summary class="mobile-facets__summary">
                        <div>
                          <span>{{ filter.label | escape }}</span>
                          <span class="mobile-facets__arrow">
                            {{- 'icon-arrow.svg' | inline_asset_content -}}
                          </span>
                        </div>
                      </summary>
                      <div
                        id="FacetMobile-{{ forloop.index }}-{{ section.id }}"
                        class="mobile-facets__submenu"
                      >
                        <button
                          class="mobile-facets__close-button"
                          aria-expanded="true"
                          type="button"
                        >
                          {{- 'icon-arrow.svg' | inline_asset_content -}}
                          <span>{{ filter.label | escape }}</span>
                          {%- if filter.operator == 'AND' -%}
                            <span class="facets__and-helptext">
                              {{ 'products.facets.filter_and_operator_subtitle' | t }}
                            </span>
                          {%- endif -%}
                        </button>
                        <ul class="{{ visual_layout_class }} mobile-facets__list" role="list">
                          {%- liquid
                            assign sorted_values = filter.values
                            # Keep the selected values grouped together when operator is AND
                            if filter.operator == 'AND'
                              assign active_filter_values = filter.values | where: 'active', true
                              assign inactive_filter_values = filter.values | where: 'active', false
                              assign sorted_values = active_filter_values | concat: inactive_filter_values
                            endif
                          -%}
                          {%- for value in sorted_values -%}
                            {% liquid
                              assign input_id = 'Filter-' | append: filter.param_name | escape | append: '-mobile-' | append: forloop.index
                              assign is_disabled = false
                              if value.count == 0 and value.active == false
                                assign is_disabled = true
                              endif
                            %}

                            {%- capture label_class -%}
                            facets__label mobile-facets__label{% if is_disabled %} disabled{% endif %}{% if value.active %} active{% endif %}
                            {%- endcapture -%}

                            {%- capture text_value -%}
                              <span class="facet-checkbox__text" aria-hidden="true">
                                <span class="facet-checkbox__text-label">{{- value.label | escape }}</span> ({{- value.count -}})
                              </span>
                              <span class="visually-hidden">
                                {{- value.label | escape }} (
                                {%- if value.count == '1' -%}
                                  {{- 'products.facets.product_count_simple.one' | t: count: value.count -}}
                                {%- else -%}
                                  {{- 'products.facets.product_count_simple.other' | t: count: value.count -}}
                                {%- endif -%}
                                )
                              </span>
                            {%- endcapture -%}

                            <li class="mobile-facets__item">
                              {% if presentation == 'swatch' %}
                                <div class="{{ label_class }}">
                                  <div class="swatch-input-wrapper">
                                    {% render 'swatch-input',
                                      id: input_id,
                                      type: 'checkbox',
                                      name: value.param_name,
                                      value: value.value,
                                      product_form_id: 'FacetFiltersFormMobile',
                                      swatch: value.swatch,
                                      checked: value.active,
                                      disabled: is_disabled
                                    %}
                                  </div>

                                  {{ text_value }}
                                </div>
                              {% else %}
                                <label for="{{ input_id }}" class="{{ label_class }}">
                                  <input
                                    class="mobile-facets__checkbox"
                                    type="checkbox"
                                    name="{{ value.param_name }}"
                                    value="{{ value.value }}"
                                    id="{{ input_id }}"
                                    {% if value.active %}
                                      checked
                                    {% endif %}
                                    {% if is_disabled %}
                                      disabled
                                    {% endif %}
                                  >

                                  {%- if presentation == 'image' -%}
                                    <div class="facets__image-wrapper">
                                      {%- if value.image -%}
                                        {{
                                          value.image
                                          | image_url: width: 165
                                          | image_tag:
                                            loading: 'lazy',
                                            widths: '82, 108, 165, 216, 330',
                                            sizes: '(min-width: 990px) 8rem, 5.4rem',
                                            class: 'facets__image',
                                            alt: value.alt
                                        }}
                                      {%- endif -%}
                                    </div>
                                  {%- else -%}
                                    <span class="mobile-facets__highlight"></span>
                                    {{- 'square.svg' | inline_asset_content -}}
                                    <span class="facets__checkmark">
                                      {{- 'icon-checkmark.svg' | inline_asset_content -}}
                                    </span>
                                  {%- endif %}

                                  {{ text_value }}
                                </label>
                              {% endif %}
                            </li>
                          {%- endfor -%}
                        </ul>

                        <div class="mobile-facets__footer">
                          <facet-remove class="mobile-facets__clear-wrapper">
                            <a href="{{ filter.url_to_remove }}" class="mobile-facets__clear">
                              {{- 'products.facets.clear' | t -}}
                            </a>
                          </facet-remove>
                          <button
                            type="button"
                            class="mobile-facets__apply"
                            onclick="this.closest('.mobile-facets__wrapper').querySelector('summary').click()"
                          >
                            {{ 'products.facets.apply' | t }}
                          </button>
                        </div>
                      </div>
                    </details>
                  {% when 'price_range' %}
                    <details
                      id="Details-Mobile-{{ filter.param_name | escape }}-{{ section.id }}"
                      class="mobile-facets__details js-filter"
                      data-index="mobile-{{ forloop.index }}"
                    >
                      <summary class="mobile-facets__summary">
                        <div>
                          <span>{{ filter.label | escape }}</span>
                          <span class="mobile-facets__arrow">
                            {{- 'icon-arrow.svg' | inline_asset_content -}}
                          </span>
                        </div>
                      </summary>
                      <div
                        id="FacetMobile-{{ forloop.index }}-{{ section.id }}"
                        class="mobile-facets__submenu"
                      >
                        <button
                          class="mobile-facets__close-button"
                          aria-expanded="true"
                          type="button"
                        >
                          {{- 'icon-arrow.svg' | inline_asset_content -}}
                          {{ filter.label | escape }}
                        </button>

                        {%- assign max_price_amount = filter.range_max | money | strip_html | escape -%}
                        <p class="mobile-facets__info">
                          {{ 'products.facets.max_price' | t: price: max_price_amount }}
                        </p>

                        <price-range class="facets__price">
                          {% render 'price-facet', filter: filter, id_prefix: 'Mobile-Filter-' %}
                        </price-range>
                        <div class="mobile-facets__footer">
                          <facet-remove class="mobile-facets__clear-wrapper">
                            <a href="{{ filter.url_to_remove }}" class="mobile-facets__clear">
                              {{- 'products.facets.clear' | t -}}
                            </a>
                          </facet-remove>
                          <button
                            type="button"
                            class="mobile-facets__apply"
                            onclick="this.closest('.mobile-facets__wrapper').querySelector('summary').click()"
                          >
                            {{ 'products.facets.apply' | t }}
                          </button>
                        </div>
                      </div>
                    </details>
                {% endcase %}
              {%- endfor -%}
            {%- endif -%}

            {%- if enable_sorting -%}
              <div
                id="Details-Mobile-SortBy-{{ section.id }}"
                class="mobile-facets__details js-filter{% if filter_type == 'drawer' %} desktop:hidden{% endif %}"
                data-index="mobile-{{ forloop.index }}"
              >
                <div class="mobile-facets__summary">
                  <div class="mobile-facets__sort">
                    <label for="SortBy-mobile">{{ 'products.facets.sort_by_label' | t }}</label>
                    <div class="facets-select">
                      <select
                        name="sort_by"
                        class="facets-select__select"
                        id="SortBy-mobile"
                        aria-describedby="a11y-refresh-page-message"
                      >
                        {%- for option in results.sort_options -%}
                          <option
                            value="{{ option.value | escape }}"
                            {% if option.value == sort_by %}
                              selected="selected"
                            {% endif %}
                          >
                            {{ option.name | escape }}
                          </option>
                        {%- endfor -%}
                      </select>
                      <span class="facets-select__caret">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            {%- endif -%}

            <div class="mobile-facets__footer">
              <facet-remove class="mobile-facets__clear-wrapper">
                <a href="{{ results_url }}" class="mobile-facets__clear">
                  {{- 'products.facets.clear_all' | t -}}
                </a>
              </facet-remove>
              <button
                type="button"
                class="mobile-facets__apply"
                onclick="this.closest('.mobile-facets__wrapper').querySelector('summary').click()"
              >
                {{ 'products.facets.apply' | t }}
              </button>
            </div>
          </div>

          {% if results.current_vendor or results.current_type %}
            <input type="hidden" name="q" value="{{ results.current_vendor }}{{ results.current_type }}">
          {% endif %}

          {%- if results.terms -%}
            <input type="hidden" name="q" value="{{ results.terms | escape }}">
            <input name="options[prefix]" type="hidden" value="last">
          {%- endif -%}
        </div>
      </form>
    </facet-filters-form>
  </details>
</menu-drawer>

{% stylesheet %}
  @layer components {
    /* ── Mobile filter/sort drawer ────────────────────────────────────────────
       Dawn's component-mobile-facets / menu-drawer CSS was deleted; this block
       makes the drawer self-contained on every host (collection + search). The
       <details open> attribute (toggled by the summary) drives the slide-in. */
    .mobile-facets__wrapper {
      display: block;
    }

    .mobile-facets__disclosure {
      position: relative;
    }

    /* Trigger button row */
    .mobile-facets__open-wrapper {
      list-style: none;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      cursor: pointer;
      padding: var(--spacing-sm, 0.8rem) var(--spacing-md, 1.2rem);
      font-size: 1.4rem;
      border: var(--border-width, 1px) solid rgb(var(--color-foreground) / 0.2);
      border-radius: var(--border-radius-sm, 0.4rem);
      user-select: none;
    }

    .mobile-facets__open-wrapper::-webkit-details-marker {
      display: none;
    }

    .mobile-facets__open {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
    }

    .mobile-facets__open-icon,
    .mobile-facets__close-icon {
      display: inline-flex;
      width: 1.6rem;
      height: 1.6rem;
    }

    .mobile-facets__open-icon svg,
    .mobile-facets__close-icon svg {
      width: 100%;
      height: 100%;
      fill: currentColor;
    }

    /* The close (X) lives in the summary too; only shown while the drawer is open */
    .mobile-facets__close {
      display: none;
    }

    /* ── Open state: full-height slide-in panel ───────────────────────────── */
    .mobile-facets__disclosure[open] > .mobile-facets__open-wrapper {
      position: fixed;
      inset-block-start: 0;
      inset-inline-end: 0;
      z-index: calc(var(--z-cart-drawer, 300) + 1);
      width: 100%;
      max-width: 40rem;
      justify-content: flex-end;
      border: 0;
      border-radius: 0;
      padding: var(--spacing-md, 1.6rem);
      background: transparent;
    }

    .mobile-facets__disclosure[open] > .mobile-facets__open-wrapper .mobile-facets__open {
      display: none;
    }

    .mobile-facets__disclosure[open] > .mobile-facets__open-wrapper .mobile-facets__close {
      display: inline-flex;
    }

    .mobile-facets {
      position: fixed;
      inset-block: 0;
      inset-inline-end: 0;
      z-index: var(--z-cart-drawer, 300);
      width: 100%;
      max-width: 40rem;
      overflow-y: auto;
      background: rgb(var(--color-background));
      color: rgb(var(--color-foreground));
      box-shadow: var(--shadow-lg, -2px 0 16px rgb(var(--color-foreground) / 0.15));
    }

    .mobile-facets__inner {
      display: flex;
      flex-direction: column;
      min-height: 100%;
    }

    /* ── Drawer header ────────────────────────────────────────────────────── */
    .mobile-facets__header {
      padding: var(--spacing-md, 1.6rem);
      border-bottom: var(--border-width, 1px) solid rgb(var(--color-foreground) / 0.1);
    }

    .mobile-facets__header-inner {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.8rem;
    }

    .mobile-facets__heading {
      margin: 0;
      font-size: 1.8rem;
      font-weight: 500;
    }

    .mobile-facets__count {
      margin: 0;
      font-size: 1.3rem;
      color: rgb(var(--color-foreground) / 0.6);
    }

    .mobile-facets__main {
      flex: 1;
    }

    /* ── Each filter group (native <details>) ─────────────────────────────── */
    .mobile-facets__details {
      border-bottom: var(--border-width, 1px) solid rgb(var(--color-foreground) / 0.1);
    }

    .mobile-facets__summary {
      list-style: none;
      cursor: pointer;
      user-select: none;
      padding: var(--spacing-md, 1.6rem);
    }

    .mobile-facets__summary::-webkit-details-marker {
      display: none;
    }

    .mobile-facets__summary > div {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      font-size: 1.5rem;
      font-weight: 500;
    }

    .mobile-facets__arrow {
      display: inline-flex;
      width: 1.4rem;
      height: 1.4rem;
      transition: transform var(--duration-short, 150ms) ease;
    }

    .mobile-facets__arrow svg {
      width: 100%;
      height: 100%;
      fill: currentColor;
    }

    .mobile-facets__details[open] > .mobile-facets__summary .mobile-facets__arrow {
      transform: rotate(90deg);
    }

    .mobile-facets__submenu {
      padding: 0 var(--spacing-md, 1.6rem) var(--spacing-md, 1.6rem);
    }

    .mobile-facets__close-button {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: transparent;
      border: 0;
      padding: 0 0 var(--spacing-sm, 0.8rem);
      font-size: 1.4rem;
      font-weight: 500;
      color: inherit;
      cursor: pointer;
    }

    .mobile-facets__close-button svg {
      width: 1.4rem;
      height: 1.4rem;
      transform: rotate(180deg);
      fill: currentColor;
    }

    /* ── Value list ───────────────────────────────────────────────────────── */
    .mobile-facets__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .mobile-facets__list.facets-layout-grid {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.8rem;
    }

    .mobile-facets__item {
      margin: 0;
    }

    /* Checkbox row — input class is EXACTLY mobile-facets__checkbox (JS hook) */
    .facets__label.mobile-facets__label {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.7rem 0;
      cursor: pointer;
      font-size: 1.4rem;
    }

    .mobile-facets__checkbox {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .facets__label.mobile-facets__label > svg {
      flex: 0 0 auto;
      width: 1.6rem;
      height: 1.6rem;
      border: var(--border-width, 1px) solid rgb(var(--color-foreground) / 0.4);
      border-radius: var(--border-radius-sm, 0.3rem);
      fill: transparent;
    }

    .facets__label.mobile-facets__label .facets__checkmark {
      position: absolute;
      left: 0;
      display: inline-flex;
      width: 1.6rem;
      height: 1.6rem;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
    }

    .facets__label.mobile-facets__label .facets__checkmark svg {
      width: 1rem;
      height: 1rem;
      fill: rgb(var(--color-background));
    }

    .facets__label.mobile-facets__label.active > svg,
    .facets__label.mobile-facets__label input:checked ~ svg {
      background: rgb(var(--color-foreground));
      border-color: rgb(var(--color-foreground));
    }

    .facets__label.mobile-facets__label.active .facets__checkmark,
    .facets__label.mobile-facets__label input:checked ~ .facets__checkmark {
      opacity: 1;
    }

    .facets__label.mobile-facets__label.disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .mobile-facets__highlight {
      display: none;
    }

    /* ── Mobile sort row ──────────────────────────────────────────────────── */
    .mobile-facets__sort {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      padding: var(--spacing-md, 1.6rem) 0;
    }

    .mobile-facets__sort label {
      font-size: 1.5rem;
      font-weight: 500;
    }

    /* ── Drawer footers (clear / apply) ───────────────────────────────────── */
    .mobile-facets__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      padding: var(--spacing-md, 1.6rem);
    }

    .mobile-facets__main > .mobile-facets__footer {
      position: sticky;
      inset-block-end: 0;
      background: rgb(var(--color-background));
      border-top: var(--border-width, 1px) solid rgb(var(--color-foreground) / 0.1);
    }

    .mobile-facets__clear {
      font-size: 1.4rem;
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 0.3rem;
    }

    .mobile-facets__clear:hover {
      text-decoration: none;
    }

    .mobile-facets__apply {
      flex: 1;
      max-width: 18rem;
      padding: 1rem 1.6rem;
      font-size: 1.4rem;
      cursor: pointer;
      color: rgb(var(--color-background));
      background: rgb(var(--color-foreground));
      border: var(--border-width, 1px) solid rgb(var(--color-foreground));
      border-radius: var(--border-radius-sm, 0.4rem);
    }

    .mobile-facets__apply:hover {
      background: rgb(var(--color-foreground) / 0.85);
    }

    .mobile-facets__info {
      margin: 0 0 var(--spacing-sm, 0.8rem);
      font-size: 1.3rem;
      color: rgb(var(--color-foreground) / 0.6);
    }
  }
{% endstylesheet %}
