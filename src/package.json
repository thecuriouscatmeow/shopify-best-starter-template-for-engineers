{
  "name": "gujrati-theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./styles/main.css -o ./assets/main.css --minify",
    "watch:css": "tailwindcss -i ./styles/main.css -o ./assets/main.css --watch",
    "dev": "concurrently -n css,shopify -c cyan,green \"npm run watch:css\" \"shopify theme dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.0"
  }
}
